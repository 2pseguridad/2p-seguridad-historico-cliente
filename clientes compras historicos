<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>2P Seguridad — Historial por Cliente</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;900&family=Barlow:wght@300;400;500&display=swap');

  :root {
    --bg:#0d0f14; --surface:#161a22; --surface2:#1e2330;
    --border:#2a3040; --accent:#f5a623; --text:#e8ecf0;
    --muted:#6b7a8d; --green:#27c06a;
    --c22:#9b7fd4; --c23:#e05c8a; --c24:#26c6da; --c25:#4a9eff; --c26:#f5a623;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { background:var(--bg); color:var(--text); font-family:'Barlow',sans-serif; min-height:100vh; }

  /* ── HEADER ── */
  header {
    background:var(--surface); border-bottom:3px solid var(--accent);
    padding:14px 28px; display:flex; align-items:center; gap:14px;
    position:sticky; top:0; z-index:100; flex-wrap:wrap;
  }
  .logo { font-family:'Barlow Condensed',sans-serif; font-weight:900; font-size:1.7rem; letter-spacing:2px; color:var(--accent); text-transform:uppercase; line-height:1; }
  .logo span { color:var(--text); }
  .subtitle { color:var(--muted); font-size:0.72rem; letter-spacing:1px; text-transform:uppercase; margin-top:3px; }
  .header-right { margin-left:auto; display:flex; align-items:center; gap:6px; flex-wrap:wrap; }
  .badge { background:var(--surface2); border:1px solid var(--border); border-radius:4px; padding:4px 9px; font-size:0.7rem; color:var(--muted); font-family:'Barlow Condensed',sans-serif; letter-spacing:1px; text-transform:uppercase; white-space:nowrap; }
  .badge strong { font-weight:700; }

  /* ── MODE TABS (top-level) ── */
  .mode-bar {
    background:var(--surface2); border-bottom:1px solid var(--border);
    display:flex; padding:0 28px;
  }
  .mode-tab {
    padding:11px 22px; font-family:'Barlow Condensed',sans-serif; font-weight:700;
    font-size:0.9rem; letter-spacing:1.5px; text-transform:uppercase;
    color:var(--muted); cursor:pointer; border-bottom:3px solid transparent;
    transition:all .2s;
  }
  .mode-tab:hover { color:var(--text); }
  .mode-tab.active { color:var(--accent); border-color:var(--accent); }

  /* ── SHARED FILTER AREA ── */
  .view { display:none; }
  .view.active { display:block; }

  .filters { padding:20px 28px 0; max-width:1280px; margin:0 auto; display:flex; gap:10px; align-items:flex-end; flex-wrap:wrap; }
  .filter-group { display:flex; flex-direction:column; gap:5px; flex:1; min-width:180px; }
  .filter-label { font-family:'Barlow Condensed',sans-serif; font-size:0.7rem; letter-spacing:2px; text-transform:uppercase; color:var(--muted); }
  .search-wrap { position:relative; }
  .search-input {
    width:100%; background:var(--surface); border:2px solid var(--border); border-radius:6px;
    padding:10px 14px 10px 40px; color:var(--text); font-family:'Barlow',sans-serif;
    font-size:0.92rem; outline:none; transition:border-color .2s;
  }
  .search-input:focus { border-color:var(--accent); }
  .search-input::placeholder { color:var(--muted); }
  .search-icon { position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--muted); font-size:0.9rem; pointer-events:none; }

  .year-filter { display:flex; gap:5px; flex-wrap:wrap; }
  .year-btn {
    background:var(--surface); border:2px solid var(--border); border-radius:6px;
    padding:8px 13px; color:var(--muted); font-family:'Barlow Condensed',sans-serif;
    font-weight:700; font-size:0.88rem; letter-spacing:1px; cursor:pointer; transition:all .2s;
  }
  .year-btn:hover { border-color:var(--accent); color:var(--text); }
  .year-btn.active { color:#000; }
  .year-btn[data-y="all"].active  { border-color:var(--green); background:var(--green); }
  .year-btn[data-y="2022"].active { border-color:var(--c22); background:var(--c22); }
  .year-btn[data-y="2023"].active { border-color:var(--c23); background:var(--c23); }
  .year-btn[data-y="2024"].active { border-color:var(--c24); background:var(--c24); }
  .year-btn[data-y="2025"].active { border-color:var(--c25); background:var(--c25); }
  .year-btn[data-y="2026"].active { border-color:var(--c26); background:var(--c26); }

  .results-count { padding:10px 28px 0; max-width:1280px; margin:0 auto; font-size:0.79rem; color:var(--muted); }
  .results-count strong { color:var(--accent); }

  /* ── CLIENT CARDS GRID ── */
  .cards-grid { padding:12px 28px 60px; max-width:1280px; margin:0 auto; display:grid; grid-template-columns:repeat(auto-fill,minmax(370px,1fr)); gap:12px; }

  .client-card { background:var(--surface); border:1px solid var(--border); border-radius:8px; overflow:hidden; transition:border-color .2s; }
  .client-card:hover { border-color:#3a4560; }
  .client-card.expanded { border-color:var(--accent); }

  .card-header { padding:12px 15px; display:flex; align-items:center; gap:10px; background:var(--surface2); cursor:pointer; user-select:none; }
  .card-header:hover { background:#232a38; }
  .client-initial { width:34px; height:34px; border-radius:5px; display:flex; align-items:center; justify-content:center; font-family:'Barlow Condensed',sans-serif; font-weight:900; font-size:1rem; color:#000; flex-shrink:0; }
  .client-name { font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:0.93rem; line-height:1.2; flex:1; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  .year-dots { display:flex; gap:3px; flex-shrink:0; }
  .ydot { width:8px; height:8px; border-radius:2px; opacity:.25; }
  .ydot.active { opacity:1; }
  .expand-icon { color:var(--muted); font-size:0.82rem; flex-shrink:0; margin-left:3px; transition:transform .25s; }
  .client-card.expanded .expand-icon { transform:rotate(180deg); }

  .card-stats { display:flex; border-bottom:1px solid var(--border); overflow-x:auto; }
  .stat-block { flex:1; min-width:90px; padding:8px 12px; border-right:1px solid var(--border); }
  .stat-block:last-child { border-right:none; }
  .stat-block.empty { opacity:.3; }
  .stat-year { font-size:0.62rem; font-family:'Barlow Condensed',sans-serif; letter-spacing:1px; text-transform:uppercase; margin-bottom:3px; font-weight:700; }
  .stat-row { display:flex; flex-direction:column; gap:3px; }
  .stat-item { display:flex; justify-content:space-between; align-items:baseline; gap:6px; }
  .stat-val { font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:0.88rem; white-space:nowrap; }
  .stat-val.money { color:var(--accent); }
  .stat-val.inv { color:var(--green); }
  .stat-lbl { font-size:0.62rem; color:var(--muted); text-transform:uppercase; letter-spacing:0.7px; }

  .year-tabs { display:none; border-bottom:1px solid var(--border); overflow-x:auto; }
  .client-card.expanded .year-tabs { display:flex; }
  .year-tab { flex:1; min-width:70px; padding:7px 6px; text-align:center; font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:0.8rem; letter-spacing:0.8px; cursor:pointer; border-bottom:2px solid transparent; color:var(--muted); transition:all .15s; white-space:nowrap; }
  .year-tab:hover { color:var(--text); }
  .year-tab.disabled { opacity:.25; cursor:not-allowed; }

  .products-panel { display:none; }
  .client-card.expanded .products-panel.visible { display:block; }
  .products-list { padding:8px 15px 14px; }
  .prod-header { display:grid; grid-template-columns:1fr 56px 94px; gap:6px; padding:0 0 5px; border-bottom:1px solid var(--border); margin-bottom:1px; }
  .prod-header span { font-size:0.62rem; color:var(--muted); text-transform:uppercase; letter-spacing:1px; font-family:'Barlow Condensed',sans-serif; }
  .prod-header span:nth-child(2), .prod-header span:nth-child(3) { text-align:right; }
  .product-row { display:grid; grid-template-columns:1fr 56px 94px; gap:6px; align-items:center; padding:6px 0; border-bottom:1px solid var(--border); }
  .product-row:last-child { border-bottom:none; }
  .product-name { font-size:0.83rem; color:var(--text); line-height:1.3; }
  .product-code { font-size:0.66rem; color:var(--muted); font-family:'Barlow Condensed',monospace; margin-top:1px; }
  .product-qty  { font-family:'Barlow Condensed',sans-serif; font-weight:600; font-size:0.85rem; color:var(--green); text-align:right; white-space:nowrap; }
  .product-total{ font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:0.88rem; color:var(--accent); text-align:right; white-space:nowrap; }
  .no-data { text-align:center; color:var(--muted); font-size:0.8rem; padding:16px; font-style:italic; }

  /* ── PRODUCT VIEW ── */
  .prod-search-area { padding:20px 28px 0; max-width:1280px; margin:0 auto; }
  .prod-hint { margin-top:10px; font-size:0.78rem; color:var(--muted); }
  .prod-hint strong { color:var(--accent); }

  /* autocomplete dropdown */
  .autocomplete-wrap { position:relative; }
  .autocomplete-list {
    position:absolute; top:calc(100% + 4px); left:0; right:0; z-index:200;
    background:var(--surface2); border:1px solid var(--border); border-radius:6px;
    max-height:260px; overflow-y:auto; display:none;
  }
  .autocomplete-list.open { display:block; }
  .ac-item {
    padding:9px 14px; font-size:0.86rem; cursor:pointer;
    border-bottom:1px solid var(--border); transition:background .12s;
  }
  .ac-item:last-child { border-bottom:none; }
  .ac-item:hover { background:var(--surface); }
  .ac-item mark { background:none; color:var(--accent); font-weight:700; }

  /* product result panel */
  .prod-result { padding:16px 28px 60px; max-width:1280px; margin:0 auto; display:none; }
  .prod-result.visible { display:block; }
  .prod-result-header {
    background:var(--surface); border:1px solid var(--border); border-radius:8px;
    padding:16px 20px; margin-bottom:16px;
    display:flex; align-items:center; gap:16px; flex-wrap:wrap;
  }
  .prod-result-name {
    font-family:'Barlow Condensed',sans-serif; font-weight:900; font-size:1.3rem;
    letter-spacing:1px; color:var(--text); flex:1;
  }
  .prod-summary { display:flex; gap:20px; flex-wrap:wrap; }
  .ps-item { display:flex; flex-direction:column; gap:2px; }
  .ps-val { font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:1.1rem; }
  .ps-val.money { color:var(--accent); }
  .ps-val.cnt   { color:var(--green); }
  .ps-lbl { font-size:0.66rem; color:var(--muted); text-transform:uppercase; letter-spacing:1px; }

  /* ranking table */
  .ranking-table { background:var(--surface); border:1px solid var(--border); border-radius:8px; overflow:hidden; }
  .rt-header {
    display:grid; grid-template-columns:36px 1fr 100px 80px 120px;
    gap:10px; padding:9px 16px;
    background:var(--surface2); border-bottom:1px solid var(--border);
  }
  .rt-header span { font-size:0.64rem; color:var(--muted); text-transform:uppercase; letter-spacing:1px; font-family:'Barlow Condensed',sans-serif; }
  .rt-header span:nth-child(3), .rt-header span:nth-child(4), .rt-header span:nth-child(5) { text-align:right; }
  .rt-row {
    display:grid; grid-template-columns:36px 1fr 100px 80px 120px;
    gap:10px; padding:10px 16px; border-bottom:1px solid var(--border);
    align-items:center; transition:background .12s;
  }
  .rt-row:last-child { border-bottom:none; }
  .rt-row:hover { background:var(--surface2); }
  .rt-rank {
    font-family:'Barlow Condensed',sans-serif; font-weight:900; font-size:1rem;
    color:var(--muted); text-align:center;
  }
  .rt-rank.top1 { color:#ffd700; }
  .rt-rank.top2 { color:#c0c0c0; }
  .rt-rank.top3 { color:#cd7f32; }
  .rt-client { font-family:'Barlow Condensed',sans-serif; font-size:0.92rem; font-weight:600; }
  .rt-years { display:flex; gap:3px; flex-wrap:wrap; }
  .rt-ypill { font-size:0.6rem; font-family:'Barlow Condensed',sans-serif; font-weight:700; padding:1px 4px; border-radius:2px; border:1px solid; }
  .rt-qty   { font-family:'Barlow Condensed',sans-serif; font-weight:600; font-size:0.92rem; color:var(--green); text-align:right; }
  .rt-total { font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:0.92rem; color:var(--accent); text-align:right; }
  .rt-bar-wrap { text-align:right; }
  .rt-bar { height:6px; border-radius:3px; background:var(--accent); opacity:.6; display:inline-block; min-width:4px; }

  /* bar chart */
  .bar-section { margin-bottom:16px; background:var(--surface); border:1px solid var(--border); border-radius:8px; padding:16px 20px; }
  .bar-title { font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:0.8rem; letter-spacing:1.5px; text-transform:uppercase; color:var(--muted); margin-bottom:12px; }
  .bar-item { display:flex; align-items:center; gap:10px; margin-bottom:7px; }
  .bar-label { font-size:0.78rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; width:200px; flex-shrink:0; color:var(--text); }
  .bar-track { flex:1; height:18px; background:var(--surface2); border-radius:3px; overflow:hidden; }
  .bar-fill { height:100%; border-radius:3px; background:var(--accent); transition:width .4s; }
  .bar-value { font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:0.82rem; color:var(--accent); white-space:nowrap; min-width:90px; text-align:right; }

  .empty-state { text-align:center; padding:70px 28px; color:var(--muted); grid-column:1/-1; }
  .empty-icon { font-size:2.4rem; margin-bottom:10px; opacity:.3; }

  .scroll-top { position:fixed; bottom:24px; right:24px; background:var(--accent); color:#000; border:none; border-radius:6px; width:38px; height:38px; font-size:1rem; cursor:pointer; opacity:0; transition:opacity .2s; z-index:200; font-weight:bold; }
  .scroll-top.visible { opacity:1; }

  @media(max-width:700px){
    .cards-grid{ padding:10px 10px 40px; grid-template-columns:1fr; }
    .filters, .prod-search-area, .prod-result{ padding-left:12px; padding-right:12px; }
    .results-count{ padding:8px 12px 0; }
    header{ padding:11px 14px; }
    .rt-header, .rt-row { grid-template-columns:28px 1fr 70px 65px; }
    .rt-header span:last-child, .rt-row .rt-bar-wrap { display:none; }
    .bar-label { width:120px; }
  }
</style>
</head>
<body>

<header>
  <div>
    <div class="logo">2P <span>Seguridad</span></div>
    <div class="subtitle">Historial completo por cliente</div>
  </div>
  <div class="header-right" id="header-badges"></div>
</header>

<!-- MODE TABS -->
<div class="mode-bar">
  <div class="mode-tab active" id="tab-clientes" onclick="switchMode('clientes')">👤 Por Cliente</div>
  <div class="mode-tab" id="tab-productos" onclick="switchMode('productos')">📦 Por Artículo</div>
</div>

<!-- ═══════════════ VIEW: CLIENTES ═══════════════ -->
<div class="view active" id="view-clientes">
  <div class="filters">
    <div class="filter-group">
      <div class="filter-label">Buscar cliente</div>
      <div class="search-wrap">
        <span class="search-icon">🔍</span>
        <input class="search-input" id="search" type="text" placeholder="Nombre del cliente..." autocomplete="off" spellcheck="false">
      </div>
    </div>
    <div class="filter-group" style="flex:0;min-width:auto">
      <div class="filter-label">Filtrar año</div>
      <div class="year-filter" id="year-btns"></div>
    </div>
  </div>
  <div class="results-count" id="results-count"></div>
  <div class="cards-grid" id="grid"></div>
</div>

<!-- ═══════════════ VIEW: PRODUCTOS ═══════════════ -->
<div class="view" id="view-productos">
  <div class="prod-search-area">
    <div class="filter-label" style="margin-bottom:6px">Buscar artículo</div>
    <div class="autocomplete-wrap">
      <div class="search-wrap">
        <span class="search-icon">📦</span>
        <input class="search-input" id="prod-search" type="text"
               placeholder="Ej: GUANTE SOLDADOR, CASCO, DELANTAL..." autocomplete="off" spellcheck="false">
      </div>
      <div class="autocomplete-list" id="ac-list"></div>
    </div>
    <div class="prod-hint" id="prod-hint">
      Ingresá el nombre o parte del nombre del artículo · <strong id="prod-total-count">777</strong> productos en el historial
    </div>
  </div>
  <div class="prod-result" id="prod-result"></div>
</div>

<button class="scroll-top" id="scroll-top" onclick="window.scrollTo({top:0,behavior:'smooth'})">↑</button>

