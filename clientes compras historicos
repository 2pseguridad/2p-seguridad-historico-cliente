}

// ── Build client card ──
function buildCard(cliente) {
  const d = DATA[cliente];
  const hasYear = y => d[y] && d[y].facturas > 0;
  const card = document.createElement('div');
  card.className = 'client-card';
  card.dataset.cliente = cliente.toLowerCase();
  YEARS.forEach(y => { card.dataset['h'+y] = hasYear(y)?'1':'0'; });

  const initial = cliente.trim()[0].toUpperCase();
  let initColor = '#6b7a8d';
  for(let i=YEARS.length-1;i>=0;i--){ if(hasYear(YEARS[i])){ initColor=COLORS[YEARS[i]]; break; } }

  const dots = YEARS.map(y=>`<div class="ydot ${hasYear(y)?'active':''}" style="background:${COLORS[y]}" title="${y}"></div>`).join('');

  const statsBlocks = YEARS.map(y => {
    const prods=d[y].productos||[], fc=d[y].facturas||0;
    if(!fc) return `<div class="stat-block empty"><div class="stat-year" style="color:${COLORS[y]}">${y}</div><div class="stat-lbl">—</div></div>`;
    const t=totalY(prods);
    return `<div class="stat-block">
      <div class="stat-year" style="color:${COLORS[y]}">${y}</div>
      <div class="stat-row">
        <div class="stat-item"><span class="stat-val inv">${fc}</span><span class="stat-lbl">FC</span></div>
        <div class="stat-item"><span class="stat-val">${prods.length}</span><span class="stat-lbl">prod</span></div>
        <div class="stat-item"><span class="stat-val money">${fmt(t)}</span><span class="stat-lbl">total</span></div>
      </div>
    </div>`;
  }).join('');

  let defaultTab=YEARS[YEARS.length-1];
  for(let i=YEARS.length-1;i>=0;i--){ if(hasYear(YEARS[i])){ defaultTab=YEARS[i]; break; } }

  const tabs = YEARS.map(y => {
    const fc=d[y].facturas||0;
    if(!fc) return `<div class="year-tab disabled" style="color:${COLORS[y]}">${y}</div>`;
    const isDefault = y===defaultTab;
    return `<div class="year-tab tab-btn ${isDefault?'active':''}" data-year="${y}"
      style="${isDefault?`border-color:${COLORS[y]};color:${COLORS[y]}`:''}">
      ${y} (${fc} FC)</div>`;
  }).join('');

  function prodRows(arr) {
    if(!arr||!arr.length) return '<div class="no-data">Sin datos para este año</div>';
    return `<div class="prod-header"><span>Producto</span><span>Cant.</span><span>Total</span></div>`
      + arr.map(p=>`<div class="product-row">
        <div><div class="product-name">${p.producto}</div><div class="product-code">COD: ${p.codigo}</div></div>
        <div class="product-qty">×${p.cantidad%1===0?p.cantidad:p.cantidad.toFixed(1)}</div>
        <div class="product-total">${fmt(p.total)}</div>
      </div>`).join('');
  }

  const panels = YEARS.map(y => {
    const visible = y===defaultTab?' visible':'';
    return `<div class="products-panel${visible}" data-panel="${y}"><div class="products-list">${prodRows(d[y].productos)}</div></div>`;
  }).join('');

  card.innerHTML = `
    <div class="card-header">
      <div class="client-initial" style="background:${initColor}">${initial}</div>
      <div class="client-name" title="${cliente}">${cliente}</div>
      <div class="year-dots">${dots}</div>
      <div class="expand-icon">▾</div>
    </div>
    <div class="card-stats">${statsBlocks}</div>
    <div class="year-tabs">${tabs}</div>
    ${panels}`;

  card.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', e => {
      e.stopPropagation();
      const y=btn.dataset.year;
      card.querySelectorAll('.tab-btn').forEach(b => {
        const it=b.dataset.year===y;
        b.classList.toggle('active',it);
        b.style.borderColor=it?COLORS[y]:'transparent';
        b.style.color=it?COLORS[y]:'';
      });
      card.querySelectorAll('.products-panel').forEach(p=>{
        p.classList.toggle('visible',p.dataset.panel===y);
      });
    });
  });
  card.querySelector('.card-header').addEventListener('click',()=>card.classList.toggle('expanded'));
  return card;
}

