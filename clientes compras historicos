let acTimeout = null;

prodSearchEl.addEventListener('input', () => {
  clearTimeout(acTimeout);
  acTimeout = setTimeout(updateAutocomplete, 120);
});

prodSearchEl.addEventListener('keydown', e => {
  if(e.key==='Escape') closeAC();
  if(e.key==='Enter') {
    const first = acList.querySelector('.ac-item');
    if(first) { selectProduct(first.dataset.prod); closeAC(); }
  }
});

document.addEventListener('click', e => {
  if(!e.target.closest('.autocomplete-wrap')) closeAC();
});

function closeAC() { acList.classList.remove('open'); acList.innerHTML=''; }

function highlight(str, q) {
  if(!q) return str;
  const idx = str.toLowerCase().indexOf(q.toLowerCase());
  if(idx<0) return str;
  return str.slice(0,idx)+'<mark>'+str.slice(idx,idx+q.length)+'</mark>'+str.slice(idx+q.length);
}

function updateAutocomplete() {
  const q = prodSearchEl.value.trim().toUpperCase();
  if(q.length < 2) { closeAC(); return; }
  const matches = prodKeys.filter(k => k.includes(q)).slice(0, 40);
  if(!matches.length) { closeAC(); return; }
  acList.innerHTML = matches.map(p => {
    const cnt = PROD_INDEX[p].length;
    return `<div class="ac-item" data-prod="${p.replace(/"/g,'&quot;')}">
      ${highlight(p,q)}
      <span style="color:var(--muted);font-size:0.75rem;float:right">${cnt} cliente${cnt!==1?'s':''}</span>
    </div>`;
  }).join('');
  acList.querySelectorAll('.ac-item').forEach(item => {
    item.addEventListener('click', () => { selectProduct(item.dataset.prod); closeAC(); });
  });
  acList.classList.add('open');
}

function selectProduct(prod) {
  prodSearchEl.value = prod;
  closeAC();
  showProductRanking(prod);
}

function showProductRanking(prod) {
  const rows = PROD_INDEX[prod];
  if(!rows || !rows.length) { prodResult.classList.remove('visible'); return; }

  const maxTotal   = rows[0].total;
  const grandTotal = rows.reduce((s,r)=>s+r.total, 0);
  const grandQty   = rows.reduce((s,r)=>s+r.cantidad, 0);

  // Top 10 bar chart
  const top10 = rows.slice(0, 10);
  const barItems = top10.map(r => {
    const pct = maxTotal > 0 ? (r.total/maxTotal*100).toFixed(1) : 0;
    return `<div class="bar-item">
      <div class="bar-label" title="${r.cliente}">${r.cliente}</div>
      <div class="bar-track"><div class="bar-fill" style="width:${pct}%"></div></div>
      <div class="bar-value">${fmt(r.total)}</div>
    </div>`;
  }).join('');

  // Full ranking table
  const tableRows = rows.map((r,i) => {
    const rankCls = i===0?'top1':i===1?'top2':i===2?'top3':'';
    const pct = maxTotal>0?(r.total/maxTotal*100).toFixed(0):0;
    const ypills = r.years.map(y=>`<span class="rt-ypill" style="color:${COLORS[y]||'#888'};border-color:${COLORS[y]||'#888'}">${y}</span>`).join('');
    return `<div class="rt-row">
      <div class="rt-rank ${rankCls}">${i+1}</div>
      <div>
        <div class="rt-client">${r.cliente}</div>
        <div class="rt-years">${ypills}</div>
      </div>
      <div class="rt-qty">×${r.cantidad%1===0?r.cantidad:r.cantidad.toFixed(1)}</div>
      <div class="rt-total">${fmt(r.total)}</div>
      <div class="rt-bar-wrap"><div class="rt-bar" style="width:${Math.max(4,pct)}px;max-width:100px"></div></div>
    </div>`;
  }).join('');

  prodResult.innerHTML = `
    <div class="prod-result-header">
      <div class="prod-result-name">📦 ${prod}</div>
      <div class="prod-summary">
        <div class="ps-item"><span class="ps-val cnt">${rows.length}</span><span class="ps-lbl">clientes</span></div>
        <div class="ps-item"><span class="ps-val cnt">×${Math.round(grandQty).toLocaleString('es-AR')}</span><span class="ps-lbl">unidades</span></div>
        <div class="ps-item"><span class="ps-val money">${fmt(grandTotal)}</span><span class="ps-lbl">total histórico</span></div>
      </div>
    </div>
    ${top10.length > 1 ? `<div class="bar-section"><div class="bar-title">Top ${top10.length} por monto facturado</div>${barItems}</div>` : ''}
    <div class="ranking-table">
      <div class="rt-header">
        <span>#</span><span>Cliente</span><span>Total</span><span>Cant.</span><span>Participación</span>
      </div>
      ${tableRows}
    </div>`;
  prodResult.classList.add('visible');
  prodResult.scrollIntoView({behavior:'smooth', block:'start'});
}

// ── Scroll top ──
window.addEventListener('scroll',()=>{
  document.getElementById('scroll-top').classList.toggle('visible', window.scrollY>400);
});
</script>
